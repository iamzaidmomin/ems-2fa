# App
APP_NAME=twofa
DEBUG=true

# SQLite
DATABASE_URL=sqlite:///./twofa.db

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_SEND_COOLDOWN_SECONDS=60
OTP_PEPPER=change-me-to-a-random-secret

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true
